# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/collabill_db

# Public app URL used in emails and redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# For sending emails (e.g., password reset, invitations)
# You can use a service like Brevo, SendGrid, or Resend
BREVO_API_KEY=""
MAIL_FROM="Collabill <noreply@yourdomain.com>"

# Optional seed data overrides
SEED_OWNER_EMAIL=owner@collabill.local
SEED_COLLABORATOR_EMAIL=collab@collabill.local
SEED_PASSWORD=password123
