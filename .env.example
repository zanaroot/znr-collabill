# Database (required)
DATABASE_URL=

# Encryption (required)
# Must be at least 32 characters
ENCRYPTION_KEY=

# S3/MinIO (required)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_BUCKET=my-buckets
S3_REGION=us-east-1

# App Config (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_S3_ENDPOINT=http://localhost:9000

# Global Integrations (optional - can also be configured per-organization)
# These serve as fallbacks when no organization-specific credentials are set
# GITHUB_TOKEN=
# BREVO_API_KEY=
# MAIL_FROM=

# Seeding (optional - defaults provided)
# SEED_OWNER_EMAIL=owner@collabill.local
# SEED_ADMIN_EMAIL=admin@collabill.local
# SEED_COLLABORATOR_EMAIL=collab@collabill.local
# SEED_PASSWORD=password123