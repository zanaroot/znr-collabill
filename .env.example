# =============================================================================
# Build-time Environment Variables
# These are required when building the Docker image and get baked into the bundle
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_S3_ENDPOINT=http://localhost:9100
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# =============================================================================
# Runtime Environment Variables (Secrets)
# These should be configured as GitHub Environment Secrets
# =============================================================================

DATABASE_URL=postgresql://collabill_user:collabill_password@postgres:5432/collabill_db
ENCRYPTION_KEY=build-placeholder-12345678901234567890123456789012
MINIO_ROOT_PASSWORD=minio_root_password
S3_SECRET_KEY=minio_user_secret
POSTGRES_PASSWORD=collabill_password
BREVO_API_KEY=

# =============================================================================
# Runtime Environment Variables (Non-Secrets)
# These can be configured as GitHub Environment Variables
# =============================================================================

POSTGRES_DB=collabill_db
POSTGRES_USER=collabill_user
MINIO_ROOT_USER=minio_root_user
S3_ACCESS_KEY=minio_user
S3_BUCKET=my-buckets
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
MAIL_FROM=

# =============================================================================
# Image Configuration (used by docker-compose.prod.yml)
# The deploy workflow sets this automatically from GitHub Container Registry
# =============================================================================

NEXT_IMAGE=ghcr.io/zanaroot/znr-collabill:latest
